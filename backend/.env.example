# Database connection (matches docker-compose defaults)
DATABASE_URL=postgresql://tracepoint:tracepoint_dev@localhost:5432/tracepoint

# Embedding dimension (1536 matches gemini-embedding-001 / text-embedding-004)
EMBEDDING_DIM=1536

# Gemini API (required for embeddings and planner)
GOOGLE_API_KEY=your_embedding_api_key_here
# Secondary key for clerk/friction helpers
GOOGLE_API_KEY2=your_clerk_api_key_here

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=0.1

# Embedding model
EMBEDDING_MODEL=gemini-embedding-001

# Planner model (general reasoning)
PLANNER_MODEL=gemini-3.0

# Friction detector model (lightweight inconsistency summary)
FRICTION_MODEL=gemini-3.0-flash

# Evidence clerk model (structured metadata extraction)
EVIDENCE_CLERK_MODEL=gemini-3.0-flash-lite
