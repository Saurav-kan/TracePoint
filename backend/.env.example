# Database connection (matches docker-compose defaults)
DATABASE_URL=postgresql://tracepoint:tracepoint_dev@localhost:5432/tracepoint

# Embedding dimension (1536 matches gemini-embedding-001 / text-embedding-004)
EMBEDDING_DIM=1536

# Gemini API (required for embeddings and planner)
GOOGLE_API_KEY=your_embedding_api_key_here
# Secondary key for clerk/friction helpers
GOOGLE_API_KEY2=your_clerk_api_key_here

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=0.1

# Embedding model
EMBEDDING_MODEL=gemini-embedding-001

# Planner model (general reasoning)
PLANNER_MODEL=gemini-3.0

# Friction detector model (lightweight inconsistency summary)
FRICTION_MODEL=gemini-3.0-flash

# Evidence clerk model (structured metadata extraction)
EVIDENCE_CLERK_MODEL=gemini-3.0-flash-lite

# OpenAI (optional) for planner
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_PLANNER_MODEL=gpt-4.1-mini

# Groq (optional, OpenAI-compatible) for planner
GROQ_API_KEY=your_groq_api_key_here
GROQ_PLANNER_MODEL=gpt-oss-120b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Research agent configuration
# Enable temporal filtering on evidence timestamps (true/false)
RESEARCH_TIME_FILTER_ENABLED=false
# Distance metric for pgvector: "cosine" or "l2"
RESEARCH_DISTANCE_METRIC=cosine
# Maximum evidence chunks to return per task
RESEARCH_TOP_K=5

# Planner provider: "gemini" (default), "openai", or "groq"
PLANNER_PROVIDER=gemini

# Judge agent configuration
# Judge provider: "groq" | "siliconflow" | "none" (none = heuristic only)
JUDGE_PROVIDER=groq
# Groq judge model (reuses GROQ_API_KEY, GROQ_BASE_URL)
GROQ_JUDGE_MODEL=gpt-oss-120b
# SiliconFlow (OpenAI-compatible) for judge
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_JUDGE_MODEL=Qwen/Qwen3-VL-30B-A3B-Thinking
# If true, final verdict sees raw evidence chunks; false = only sub-answers
JUDGE_FINAL_VIEW_CHUNKS=false
# If true, require every key_fact to have at least one valid evidence_indices
JUDGE_GATEKEEPER_STRICT_LINKING=false
# Max judge retries when gatekeeper fails (1 initial + this many retries)
JUDGE_GATEKEEPER_RETRY_COUNT=2
